{
    "name": "quanzo/neuronapp",
    "description": "neuronapp",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "symfony/console": "^6.4",
        "amphp/amp": "^3",
        "amphp/http-client": "^5",
        "neuron-core/neuron-ai": "^3",
        "html2text/html2text": "^4",
        "psr/cache": "^3.0",
        "psr/log": "^3.0",
        "amphp/parallel-functions": "^2.0",
        "quanzo/tui": "dev-main"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/quanzo/tui.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "app\\modules\\neuron\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
