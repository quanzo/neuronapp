#!/usr/bin/env bash
#
# Запуск всех PHPUnit-тестов проекта.
#
# Использование:
#   bin/test            — запустить все тесты
#   bin/test --filter X — запустить только тесты, совпадающие с фильтром X
#
# Любые дополнительные аргументы передаются напрямую в phpunit.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

exec "$PROJECT_ROOT/vendor/bin/phpunit" --colors=always "$@"
